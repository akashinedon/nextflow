// Prisma schema for NextFlow — LLM Workflow Builder
// Push to DB with: npx prisma db push

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URI")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum WorkflowRunStatus {
  SUCCESS
  FAILED
  PARTIAL
  RUNNING
}

enum RunScope {
  FULL
  PARTIAL
  SINGLE
}

enum NodeRunStatus {
  SUCCESS
  FAILED
  RUNNING
  SKIPPED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid()) @map("_id")
  clerkId   String   @unique
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workflows    Workflow[]
  workflowRuns WorkflowRun[]
}

model Workflow {
  id          String   @id @default(cuid()) @map("_id")
  name        String   @default("Untitled Workflow")
  description String?
  /// Serialized ReactFlow nodes array (WorkflowNode[])
  nodes       Json     @default("[]")
  /// Serialized ReactFlow edges array (WorkflowEdge[])
  edges       Json     @default("[]")
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  runs WorkflowRun[]

  @@index([userId])
}

model WorkflowRun {
  id         String            @id @default(cuid()) @map("_id")
  /// Null for unsaved/ad-hoc workflow executions
  workflowId String?
  userId     String
  status     WorkflowRunStatus @default(RUNNING)
  scope      RunScope          @default(FULL)
  nodeCount  Int               @default(0)
  startedAt  DateTime          @default(now())
  completedAt DateTime?
  /// Optional partial execution node IDs
  nodeIds    String[]          @default([])

  workflow Workflow?  @relation(fields: [workflowId], references: [id], onDelete: SetNull)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  nodeRuns NodeRun[]

  @@index([workflowId])
  @@index([userId])
}

model NodeRun {
  id            String        @id @default(cuid()) @map("_id")
  workflowRunId String
  nodeId        String
  nodeType      String
  /// JSON map of output handle id → value
  outputs       Json          @default("{}")
  status        NodeRunStatus @default(RUNNING)
  error         String?
  startedAt     DateTime      @default(now())
  completedAt   DateTime?

  workflowRun WorkflowRun @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)

  @@unique([workflowRunId, nodeId])
  @@index([workflowRunId])
}
